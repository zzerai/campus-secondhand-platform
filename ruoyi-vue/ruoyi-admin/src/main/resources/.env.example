# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ry
DB_USERNAME=root
DB_PASSWORD=password

# Druid监控台账号密码
DRUID_USERNAME=ruoyi
DRUID_PASSWORD=123456

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# 文件存储后端：local（本地磁盘，开发默认）| aliyun-oss（生产推荐）
STORAGE_TYPE=local

# DashScope 通义千问 API Key（用于 AI 商品审核与 AI 争议仲裁）
# 控制台申请：https://dashscope.console.aliyun.com/apiKey
# 切勿将真实 KEY 写入本文件或 application.yml，必须落到 .env（已 gitignore）或部署环境变量。
# 默认模型 qwen-plus，可在 application.yml 的 langchain4j.community.dashscope.chat-model.model-name 调整。
DASHSCOPE_API_KEY=

# 阿里云 OSS 配置（仅 STORAGE_TYPE=aliyun-oss 时需要）
# 控制台申请：https://oss.console.aliyun.com
# Endpoint 示例：oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
# 可选：自定义 CDN/域名前缀，不填则使用 https://{bucket}.{endpoint}
OSS_URL_PREFIX=

# 阿里云号码认证服务（dypnsapi）短信验证码——用于移动端注册/手机号登录
# 控制台：https://dypns.console.aliyun.com  接口文档：https://help.aliyun.com/zh/pnvs
#
# 【SIGN_NAME / TEMPLATE_CODE】
#   - SIGN_NAME：阿里云控制台审核通过的短信签名名称；快速联调可用阿里云提供的公共测试签名（控制台可见）
#   - TEMPLATE_CODE：短模板 ID（形如 SMS_123456789 或公共测试模板 100001），不是模板正文
#   - REGISTER / LOGIN 两个 TEMPLATE_CODE 建议按场景拆分，便于审核合规与统计；联调期可临时共用同一个
#
# 【TEMPLATE_PARAM】（最易踩坑！）
#   阿里云 SendSmsVerifyCode 接口要求 TemplateParam 含一个 ${code} 占位符变量，值固定为字符串 "##code##"，
#   阿里云自动将其替换为生成的 6 位验证码。其他变量（如 ${min} 表示有效分钟）按实际值填写。
#   单引号包 JSON 避免 dotenv 把花括号当词边界（双引号也行但需对内部 " 转义）。
#   常见模板 → TEMPLATE_PARAM 写法：
#     1) 模板正文"您的验证码${code}"
#        TEMPLATE_PARAM='{"code":"##code##"}'
#     2) 模板正文"您的验证码${code}，${min}分钟内有效"（公共测试模板 100001 即此）
#        TEMPLATE_PARAM='{"code":"##code##","min":"5"}'
#   ⚠️ 不要漏掉 code 字段，阿里云会回"模版变量code内容非法"；也不要把 ##code## 写成真实数字。
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE_REGISTER=
ALIYUN_SMS_TEMPLATE_CODE_LOGIN=
ALIYUN_SMS_TEMPLATE_CODE_RESET_PASSWORD=
ALIYUN_SMS_TEMPLATE_CODE_CHANGE_PHONE=
ALIYUN_SMS_TEMPLATE_PARAM_REGISTER='{"code":"##code##"}'
ALIYUN_SMS_TEMPLATE_PARAM_LOGIN='{"code":"##code##"}'
ALIYUN_SMS_TEMPLATE_PARAM_RESET_PASSWORD='{"code":"##code##"}'
ALIYUN_SMS_TEMPLATE_PARAM_CHANGE_PHONE='{"code":"##code##"}'
# 可选：号码认证方案名称（启用方案时填）
ALIYUN_SMS_SCHEME_NAME=

# Alipay sandbox payment configuration
# Get these from Alipay Open Platform sandbox. Do not commit real keys.
ALIPAY_APP_ID=
ALIPAY_MERCHANT_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
# notify-url must be publicly reachable by Alipay, for example an ngrok URL during local testing.
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
