<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.trade.mapper.TrTradeCategoryMapper">
    
    <resultMap type="TrTradeCategory" id="TrTradeCategoryResult">
        <result property="categoryId"    column="category_id"    />
        <result property="categoryName"    column="category_name"    />
        <result property="parentId"    column="parent_id"    />
        <result property="sort"    column="sort"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTrTradeCategoryVo">
        select category_id, category_name, parent_id, sort, status, create_by, create_time, update_by, update_time, del_flag, remark from tr_trade_category
    </sql>

    <select id="selectTrTradeCategoryList" parameterType="TrTradeCategory" resultMap="TrTradeCategoryResult">
        <include refid="selectTrTradeCategoryVo"/>
        <where>
            del_flag = '0'
            <if test="categoryName != null  and categoryName != ''"> and category_name like concat('%', #{categoryName}, '%')</if>
            <if test="parentId != null "> and parent_id = #{parentId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by parent_id asc, sort asc, category_id asc
    </select>

    <select id="selectTrTradeCategoryByCategoryId" parameterType="Long" resultMap="TrTradeCategoryResult">
        <include refid="selectTrTradeCategoryVo"/>
        where category_id = #{categoryId} and del_flag = '0'
    </select>

    <insert id="insertTrTradeCategory" parameterType="TrTradeCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into tr_trade_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTrTradeCategory" parameterType="TrTradeCategory">
        update tr_trade_category
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where category_id = #{categoryId}
    </update>

    <update id="deleteTrTradeCategoryByCategoryId" parameterType="Long">
        update tr_trade_category set del_flag = '2', update_time = sysdate() where category_id = #{categoryId}
    </update>

    <update id="deleteTrTradeCategoryByCategoryIds" parameterType="String">
        update tr_trade_category set del_flag = '2', update_time = sysdate() where category_id in
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </update>

    <select id="checkCategoryNameUnique" resultMap="TrTradeCategoryResult">
        <include refid="selectTrTradeCategoryVo"/>
        where category_name = #{categoryName}
          and parent_id =
          <choose>
              <when test="parentId != null">#{parentId}</when>
              <otherwise>0</otherwise>
          </choose>
          and del_flag = '0'
        limit 1
    </select>

    <select id="countChildrenByCategoryId" parameterType="Long" resultType="int">
        select count(1) from tr_trade_category where parent_id = #{categoryId} and del_flag = '0'
    </select>

    <select id="countGoodsByCategoryId" parameterType="Long" resultType="int">
        select count(1) from tr_trade_goods where category_id = #{categoryId} and del_flag = '0'
    </select>
</mapper>